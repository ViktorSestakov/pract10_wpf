    <Page x:Class="prakt8_wpf.pages.ChangingPatient"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:prakt8_wpf.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="600"
      Title="ChangingPatient">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="300"/>
        </Grid.RowDefinitions>
        <StackPanel HorizontalAlignment="Left" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2">
            <TextBlock Text="Изменение информации пациента" FontSize="19"/>
        </StackPanel>
        <StackPanel Grid.Column="0" Grid.Row="1" Grid.RowSpan="3">
            <Label Content="Имя:" Margin="0 0 0 15"/>
            <Label Content="Фамилия:" Margin="0 0 0 15"/>
            <Label Content="Отчество:" Margin="0 0 0 17"/>
            <Label Content="Номер телефона:" Margin="0 0 0 24"/>
            <Label Content="Дата рождения:"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Grid.Row="1" Grid.RowSpan="3">
            <TextBox x:Name="name" Margin="4" Text="{Binding Name, Mode=TwoWay}"/>
            <TextBlock Text="Поле не может быть пустым!" Foreground="Red" x:Name="name_er" Visibility="Hidden"/>
            <TextBox x:Name="lastname" Margin="4" Text="{Binding LastName, Mode=TwoWay}"/>
            <TextBlock Text="Поле не может быть пустым!" Foreground="Red" x:Name="name_er1" Visibility="Hidden"/>
            <TextBox x:Name="midname" Margin="4" Text="{Binding MiddleName, Mode=TwoWay}"/>
            <TextBlock Text="Поле не может быть пустым!" Foreground="Red" x:Name="name_er2" Visibility="Hidden"/>
            <TextBox x:Name="number" Margin="5" Text="{Binding Number, Mode=TwoWay}"/>
            <TextBlock Text="Поле не может быть пустым!" Foreground="Red" x:Name="name_er3" Visibility="Hidden"/>
            <DatePicker x:Name="bd" Margin="5" Text="{Binding Birthday, Mode=TwoWay}"/>
            <TextBlock Text="Поле не может быть пустым!" Foreground="Red" x:Name="name_er4" Visibility="Hidden"/>
            <Button Width="80" Height="20" Content="Сохранить" HorizontalAlignment="Right" Margin="0 5 5 0" Click="Save_Click" />
            <Button Width="80" Height="20" Content="Назад" HorizontalAlignment="Right" Margin="0 5 5 0" Click="GoBack_Click" />
        </StackPanel>
    </Grid>
</Page>
